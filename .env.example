# Database (SQLite - automatic with Prisma)
DATABASE_URL="file:./dev.db"

# NewsAPI (free tier: https://newsapi.org/register)
NEWS_API_KEY=

# Groq (free tier: https://console.groq.com/keys)
GROQ_API_KEY=

# Cron job security secret (generate with: openssl rand -hex 32)
CRON_SECRET=

# Optional: OpenAI (fallback if Groq not available)
OPENAI_API_KEY=
